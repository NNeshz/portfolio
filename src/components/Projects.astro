---
import { ProjectCard } from "./ProjectCard.tsx";
import type { Lang } from "../i18n/translations";
import { translations } from "../i18n/translations";

const lang = (Astro.currentLocale as Lang) ?? 'es';
const t = translations[lang].projects;
const [reentwise, meetzeen] = t.items;
---

<section class="border-b">
  <div class="max-w-4xl mx-auto px-4 py-12 border-l border-r space-y-4">
    <h2 class="text-muted-foreground mb-8">{t.title}</h2>
    <div class="grid grid-cols-1 gap-4">
      <ProjectCard
        client:load
        title={reentwise.title}
        resume={reentwise.resume}
        date={reentwise.date}
        description={reentwise.description as string[]}
        tags={reentwise.tags as string[]}
        githubUrl={reentwise.githubUrl}
        demoUrl={reentwise.demoUrl}
        seeDetailsLabel={t.seeDetails}
      />
      <ProjectCard
        client:load
        title={meetzeen.title}
        resume={meetzeen.resume}
        date={meetzeen.date}
        description={meetzeen.description as string[]}
        tags={meetzeen.tags as string[]}
        githubUrl={meetzeen.githubUrl}
        seeDetailsLabel={t.seeDetails}
      />
    </div>
  </div>
</section>
