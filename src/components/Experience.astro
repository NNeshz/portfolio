---
import { ExperienceItem } from "./ExperienceItem";
import keandoLogo from "../assets/brands/Keando.jpeg";
import yaLogo from "../assets/brands/Ya.png";
import type { Lang } from "../i18n/translations";
import { translations } from "../i18n/translations";

const lang = (Astro.currentLocale as Lang) ?? 'es';
const t = translations[lang].experience;
const [keando, cargaya, terna] = t.jobs;
---

<section class="border-b">
  <div class="max-w-4xl mx-auto px-4 py-12 border-l border-r space-y-4">
    <h2 class="text-muted-foreground mb-6">{t.title}</h2>
    <div class="relative border-l border-muted ml-3 space-y-12 pb-4">
      <div class="relative pl-8">
        <div
          class="absolute -left-[5px] top-7 h-2.5 w-2.5 rounded-full bg-muted-foreground ring-4 ring-background"
        >
        </div>
        <ExperienceItem
          client:visible
          title={keando.title}
          company={keando.company}
          logo={keandoLogo.src}
          date={keando.date}
          description={keando.description as string[]}
          tags={["React", "Next.js", "TypeScript", "Node.js", "MongoDB", "Tailwind CSS", "API REST", "WebSockets"]}
          seeMoreLabel={t.seeMore}
        />
      </div>
      <div class="relative pl-8">
        <div
          class="absolute -left-[5px] top-7 h-2.5 w-2.5 rounded-full bg-muted-foreground ring-4 ring-background"
        >
        </div>
        <ExperienceItem
          client:visible
          title={cargaya.title}
          company={cargaya.company}
          logo={yaLogo.src}
          date={cargaya.date}
          description={cargaya.description as string[]}
          tags={["React", "Next.js", "TypeScript", "Node.js", "PostgreSQL", "Express", "Stripe", "Tailwind CSS", "REST APIs"]}
          seeMoreLabel={t.seeMore}
        />
      </div>
      <div class="relative pl-8">
        <div
          class="absolute -left-[5px] top-7 h-2.5 w-2.5 rounded-full bg-muted-foreground ring-4 ring-background"
        >
        </div>
        <ExperienceItem
          client:visible
          title={terna.title}
          company={terna.company}
          date={terna.date}
          description={terna.description as string[]}
          tags={["React", "Next.js", "JavaScript", "Tailwind CSS", "Node.js", "Stripe", "MongoDB", "Vercel"]}
          seeMoreLabel={t.seeMore}
        />
      </div>
    </div>
  </div>
</section>
