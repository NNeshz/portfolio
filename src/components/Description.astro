---
import { Button } from "./ui/button";
import {
  IconBrandGithub,
  IconBrandLinkedin,
  IconBrandX,
  IconMail,
} from "@tabler/icons-react";
import Contributions from "./Contributions.astro";
import type { Lang } from "../i18n/translations";
import { translations } from "../i18n/translations";

const lang = (Astro.currentLocale as Lang) ?? 'es';
const t = translations[lang].description;
---

<section class="border-b">
  <div class="max-w-4xl mx-auto p-4 border-l border-r space-y-4">
    <p>{t.bio1}</p>
    <p>{t.bio2}</p>
    <p class="text-muted-foreground">{t.contact}</p>
    <div class="flex flex-wrap gap-2">
      <Button variant="outline">
        <a href="https://github.com/nneshz" target="_blank">
          <IconBrandGithub className="inline w-5 h-5 mr-1" />
          GitHub
        </a>
      </Button>
      <Button variant="outline">
        <a href="https://www.linkedin.com/in/nneshz/" target="_blank">
          <IconBrandLinkedin className="inline w-5 h-5 mr-1" />
          LinkedIn
        </a>
      </Button>
      <Button variant="outline">
        <a href="https://x.com/nneshz" target="_blank">
          <IconBrandX className="inline w-5 h-5 mr-1" />
          Twitter
        </a>
      </Button>
      <Button variant="outline">
        <a
          href="mailto:nneftahdez@gmail.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          <IconMail className="inline w-5 h-5 mr-1" />
          {t.email}
        </a>
      </Button>
    </div>

    <Contributions />
  </div>
</section>
